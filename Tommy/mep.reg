Windows Registry Editor Version 5.00

; these policies are from Tommy Tran's Microsoft Edge Policies
; https://github.com/TommyTran732/Microsoft-Edge-Policies

[HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Edge]
;;
; recommended corporate settings as per Microsoft Edge Policies README
;;
"DeveloperToolsAvailability"=dword:00000002
"DefaultWebUsbGuardSetting"=dword:00000002
"DefaultClipboardSetting"=dword:00000002
"DefaultJavaScriptJitSetting"=dword:00000002
"SSLErrorOverrideAllowed"=dword:00000000
;"Disable3DAPIs"=dword:00000000 ; Tommy -- "Consider setting to true. Some websites will not work without WebGL, so whether to do this highly depends on your organization." (2026-04-08)
"SmartScreenEnabled"=dword:00000000
"ScarewareBlockerProtectionEnabled"=dword:00000000
"TyposquattingCheckerEnabled"=dword:00000000
;;
; converted from Microsoft-Edge-Policies/Linux/managed.json
;;
"EnableMediaRouter"=dword:00000000
"CACertificateManagementAllowed"=dword:00000002
"CAPlatformIntegrationEnabled"=dword:00000000
;"DefaultAutomaticDownloadsSetting"=dword:00000002 ; missing from Microsoft-Edge-Policies (2026-04-08)
"DefaultGeolocationSetting"=dword:00000002
"DefaultInsecureContentSetting"=dword:00000002
"DefaultCookiesSetting"=dword:00000004
;"DefaultThirdPartyStoragePartitioningSetting"=dword:00000001 ; missing from Microsoft-Edge-Policies (obsolete) (2026-04-08)
;"DefaultFileSystemReadGuardSetting"=dword:00000002 ; Tommy -- "Jitsi needs this to work, so I am not setting it." (2026-04-08)
;"DefaultFileSystemWriteGuardSetting"=dword:00000002 ; Tommy -- "Jitsi needs this to work, so I am not setting it."  (2026-04-08)
"DefaultWebBluetoothGuardSetting"=dword:00000002
"DefaultWebHidGuardSetting"=dword:00000002
"DefaultWindowManagementSetting"=dword:00000002
"ShowPDFDefaultRecommendationsEnabled"=dword:00000000
"SpotlightExperiencesAndRecommendationsEnabled"=dword:00000000
"FeatureFlagOverridesControl"=dword:00000001
;"GamerModeEnabled"=dword:00000000 ; missing from Microsoft-Edge-Policies (obsolete) (2026-04-08)
